# Frontend Environment Variables
# Copy this to .env.local and fill in the values

# Database API URL (deployed on Render)
REACT_APP_API_URL=https://vericloud-database.onrender.com

# Voice API URL (deployed on Render)
REACT_APP_VOICE_API_URL=https://vericloud-voice.onrender.com

# Face API URL (deployed on Render)
REACT_APP_FACE_API_URL=https://vericloud-face.onrender.com

# Text API URL (deployed on Render)
REACT_APP_TEXT_API_URL=https://vericloud-text.onrender.com
